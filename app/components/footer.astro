---
import Socials from "./socials.astro";
---
<footer class="footer">
  <span class="item">© 2026 Joshua P. Ellis</span>
  <span class="item"><Socials /></span>
  <span class="item">cc by 4.0</span>
</footer>

<style lang="scss">
  @use '../styles/tokens/breakpoints' as *;

  .footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-block: var(--space-5);
    padding-inline: var(--gutter-page-mobile);
    border-top: 1px solid var(--color-ink);

    @media (min-width: $bp-lg) {
      padding-inline: var(--gutter-page);
    }
  }

  .item {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow-size);
    letter-spacing: var(--text-eyebrow-tracking);
    text-transform: uppercase;
    color: var(--color-muted);
  }
</style>
